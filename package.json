{
  "name": "pathrix-scout",
  "version": "1.0.0",
  "description": "Zero-cost, self-hosted intelligence layer for Claude. Scrapes Reddit, HN, GitHub, and 16+ RSS feeds, fuses results with RRF ranking, and exposes everything as MCP tools.",
  "type": "module",
  "bin": {
    "pathrix-scout": "./dist/bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.0.0",
    "better-sqlite3": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": ["mcp", "claude", "ai", "scout", "rss", "reddit", "hackernews", "github"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GauravSaxenaHQ/pathrix-scout-mcp"
  }
}
